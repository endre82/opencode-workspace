# OpenCode Environment Configuration
# Copy this file to .env in your environment directory

# User Configuration - Use 1000 by default
USER_ID=1000
GROUP_ID=1000
TIMEZONE=UTC

# Container Configuration
CONTAINER_NAME=opencode-{{ENV_NAME}}
HOSTNAME=opencode-{{ENV_NAME}}

# Resource Limits (optional)
# MEMORY_LIMIT=2g
# CPU_LIMIT=1.0
# SHM_SIZE=1g

# Network Configuration
NETWORK_NAME=opencode-network

# OpenCode Configuration
OPENCODE_CONFIG_DIR=/home/dev/.config/opencode

# OpenCode Config Mode
# Choose one: host | global | project
# - host:    Use ~/.opencode config (developer's personal config)
# - global:  Use shared workspace-level config (shared across all envs)
# - project: Use per-environment config (per-env, read-write)
OPENCODE_CONFIG_MODE=project

# OpenCode Config Sources (set by creation service)
OPENCODE_JSONC_SOURCE=./opencode_project_config/opencode.jsonc
OPENCODE_AUTH_SOURCE=

# Host paths (for host mode — edit manually if needed)
HOST_OPENCODE_JSONC=/home/endre/.opencode/opencode.jsonc
HOST_OPENCODE_AUTH=/home/endre/.local/share/opencode/auth.json

# SSH Configuration
# SSH_MODE: 'default' uses host ~/.ssh, 'project' uses project-based ./ssh_config
SSH_MODE=default
SSH_HOST_PATH=/home/endre/.ssh   # Host SSH directory (used when SSH_MODE=default)
SSH_PROJECT_PATH=./ssh_config    # Project SSH directory (used when SSH_MODE=project)
SSH_CONFIG=/home/endre/.ssh      # Resolved SSH path (set by creation service based on SSH_MODE)

# Workspace and Environment Paths
WORKSPACE_DIR=./workspace
OPENCODE_ENV_CONFIG=./opencode_config
WORKTREE_DIR=${WORKSPACE_DIR}.worktrees

# Server Configuration
OPENCODE_SERVER_ENABLED=true
OPENCODE_SERVER_HOST=0.0.0.0
OPENCODE_SERVER_PORT=4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
OPENCODE_SERVER_CORS=

# code-server Configuration (VSCode in Browser)
CODE_SERVER_ENABLED=true
CODE_SERVER_PORT=8096
CODE_SERVER_AUTH=password                    # Options: password, none
CODE_SERVER_PASSWORD=                        # Uses OPENCODE_SERVER_PASSWORD if empty
CODE_SERVER_DISABLE_TELEMETRY=true
CODE_SERVER_DISABLE_UPDATE_CHECK=true

# Web Management UI Configuration
WEBUI_ENABLED=true
WEBUI_PORT=9096
WEBUI_HOST=0.0.0.0
ENV_NAME={{ENV_NAME}}

# Namespace Configuration
MOUNT_NAMESPACE_GLOBAL=true
NAMESPACE_GLOBAL_DIR=../../shared/namespaces/global

# Meridian Proxy (in-container mode)
# Set MERIDIAN_ENABLED=true to run Meridian inside this container instead of calling a host proxy.
# MERIDIAN_DIR and CLAUDE_AUTH_DIR are resolved and written by the creation service.
MERIDIAN_ENABLED=false
MERIDIAN_DIR=             # Path to @rynfar/meridian package on host (set by creation service)
CLAUDE_AUTH_DIR=          # Path to ~/.claude on host (set by creation service)
CLAUDE_PROXY_PORT=3456