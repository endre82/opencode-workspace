# OpenCode Environment Configuration
# Copy this file to .env in your environment directory

# User Configuration - Use 1000 by default
USER_ID=1000
GROUP_ID=1000
TIMEZONE=UTC

# Container Configuration
CONTAINER_NAME=opencode-{{ENV_NAME}}
HOSTNAME=opencode-{{ENV_NAME}}

# Resource Limits (optional)
# MEMORY_LIMIT=2g
# CPU_LIMIT=1.0
# SHM_SIZE=1g

# Network Configuration
NETWORK_NAME=opencode-network

# OpenCode Configuration
OPENCODE_CONFIG_DIR=/home/dev/.config/opencode

# Volume Mount Control
# Set to 'true' to enable mounting, 'false' to disable
# Note: You must also uncomment corresponding volume in docker-compose.yml
MOUNT_GLOBAL_CONFIG=false        # Mount shared OpenCode config from host
MOUNT_PROJECT_CONFIG=false       # Mount project-specific .opencode config
MOUNT_OPENCODE_ENV_CONFIG=true   # Mount per-environment config (recommended)

# Opencode Volumes
# Workspace can be isolated (./workspace) or external path (~/my-env-name)
WORKSPACE_DIR=./workspace
PROJECT_CONFIG=./opencode_project_config
GLOBAL_CONFIG=../shared/config/.opencode
OPENCODE_ENV_CONFIG=./opencode_config
WORKTREE_DIR=./worktree

# Server Configuration
OPENCODE_SERVER_ENABLED=true
OPENCODE_SERVER_HOST=0.0.0.0
OPENCODE_SERVER_PORT=4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
OPENCODE_SERVER_CORS=